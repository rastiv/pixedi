{
  "name": "pixedi",
  "version": "1.0.0",
  "description": "A lightweight, embeddable React image editor component.",
  "type": "module",
  "main": "./dist/lib/index.umd.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "files": [
    "dist/lib",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build:app": "tsc -b tsconfig.app.json && vite build",
    "build:widget": "vite build --config vite.widget.config.ts --mode production",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build": "pnpm build:app && pnpm build:widget && pnpm build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc -b tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react-router": "^8.0.1"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-actions": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-onboarding": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.8.5",
    "storybook": "^8.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^27.4.0",
    "vitest": "^4.0.18"
  }
}
